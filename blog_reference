// ============================================
// ANIMATION VARIANTS
// ============================================

const containerVariants = {
  hidden: {},
  visible: {
    transition: {
      staggerChildren: 0.1, // 100ms between panels
      staggerDirection: 1,   // Top to bottom
    },
  },
};

const panelVariants = {
  hidden: {
    x: 80,
    opacity: 0,
  },
  visible: {
    x: 0,
    opacity: 1,
    transition: {
      duration: 3,
      ease: [0.25, 0.46, 0.45, 0.94], // cubic-bezier ease-out
    },
  },
};

const dividerVariants = {
  hidden: {
    x: -12,
    opacity: 0,
  },
  visible: {
    x: 0,
    opacity: 1,
    transition: {
      duration: 3,
      ease: [0.25, 0.46, 0.45, 0.94],
    },
  },
};

// ============================================
// MAIN COMPONENT
// ============================================

export const PanelAnimation = () => {
  const controls = useAnimation();
  const ref = useRef(null);
  const inView = useInView(ref, { 
    once: true, 
    amount: 0.3, // 30% visible triggers animation
  });
  
  useEffect(() => {
    if (inView) {
      controls.start('visible');
    }
  }, [inView, controls]);
  
  return (
    <div className="panel-container" ref={ref}>
      <motion.div
        variants={containerVariants}
        initial="hidden"
        animate={controls}
      >
        {panelData.map((panel, index) => (
          <SinglePanel
            key={panel.id}
            panel={panel}
            index={index}
            isFirst={index === 0}
          />
        ))}
      </motion.div>
    </div>
  );
};

// ============================================
// SINGLE PANEL COMPONENT
// ============================================

const SinglePanel = ({ panel, index, isFirst }) => {
  return (
    <motion.div
      className="panel"
      style={{ background: panel.color }}
      // First panel is always visible (no animation)
      animate={isFirst ? { x: 0, opacity: 1 } : undefined}
      transition={isFirst ? { duration: 0 } : undefined}
    >
      <div className="panel-grid">
        {/* Left side - Logo area */}
        <div className="panel-left">
          <div className="panel-logo-top">
            <svg className="panel-logo" viewBox="0 0 58 202">
              {/* SVG path */}
            </svg>
          </div>
          <div className="panel-logo-bottom">
            <svg className="panel-logo" viewBox="0 0 60 24">
              {/* SVG path */}
            </svg>
          </div>
        </div>
        
        {/* Divider line */}
        <motion.div
          className="panel-divider"
          variants={isFirst ? undefined : dividerVariants}
          animate={isFirst ? { x: 0, opacity: 1 } : undefined}
        />
        
        {/* Content */}
        <motion.div
          className="panel-content"
          variants={isFirst ? undefined : panelVariants}
          animate={isFirst ? { x: 0, opacity: 1 } : undefined}
        >
          <h2 className={`panel-title panel-title-${panel.titleClass}`}>
            {panel.title}
          </h2>
          <p className="panel-text">{panel.text}</p>
        </motion.div>
      </div>
    </motion.div>
  );
};

export default PanelAnimation;
