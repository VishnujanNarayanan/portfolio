```javascript
/**
 * PP Neue Montréal - Scroll-Triggered Panel Animation
 * 
 * This script triggers the panel animation when panels scroll into view.
 * Each panel slides in from the right with a staggered delay.
 */

// ============================================
// MAIN ANIMATION CLASS
// ============================================

class PanelAnimation {
  /**
   * Create a new PanelAnimation instance
   * @param {Object} options - Configuration options
   * @param {string} options.selector - CSS selector for panels (default: '.panel:not(:first-child)')
   * @param {number} options.threshold - Intersection threshold (0-1, default: 0.3)
   * @param {number} options.staggerDelay - Delay between panels in ms (default: 100)
   * @param {boolean} options.once - Animate only once (default: true)
   */
  constructor(options = {}) {
    // Default configuration
    this.config = {
      selector: '.panel:not(:first-child)',
      threshold: 0.3,
      staggerDelay: 100,
      once: true,
      rootMargin: '0px',
      ...options
    };
    
    this.panels = [];
    this.animated = new Set();
    this.observer = null;
    
    this.init();
  }
  
  /**
   * Initialize the animation
   */
  init() {
    // Find all panels (excluding the first one which is always visible)
    this.panels = document.querySelectorAll(this.config.selector);
    
    if (this.panels.length === 0) {
      console.warn('No panels found with selector:', this.config.selector);
      return;
    }
    
    console.log(`🎬 Found ${this.panels.length} panels to animate`);
    
    // Set up intersection observer
    this.setupObserver();
    
    // Observe each panel
    this.panels.forEach((panel) => {
      this.observer.observe(panel);
    });
  }
  
  /**
   * Set up the IntersectionObserver
   */
  setupObserver() {
    this.observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            this.animatePanel(entry.target);
          }
        });
      },
      {
        threshold: this.config.threshold,
        rootMargin: this.config.rootMargin,
      }
    );
  }
  
  /**
   * Animate a single panel
   * @param {Element} panel - The panel element to animate
   */
  animatePanel(panel) {
    // Get panel index
    const index = Array.from(this.panels).indexOf(panel);
    
    // Skip if already animated (when once: true)
    if (this.config.once && this.animated.has(index)) {
      return;
    }
    
    // Calculate stagger delay (panel 0 = 0ms, panel 1 = 100ms, etc.)
    const delay = index * this.config.staggerDelay;
    
    // Add active class with delay
    setTimeout(() => {
      panel.classList.add('active');
      this.animated.add(index);
      
      // Dispatch custom event
      panel.dispatchEvent(new CustomEvent('panelAnimated', {
        detail: { 
          index: index, 
          panel: panel,
          delay: delay 
        }
      }));
      
      console.log(`✅ Panel ${index + 1} animated (delay: ${delay}ms)`);
    }, delay);
  }
  
  /**
   * Animate a specific panel by index
   * @param {number} index - Panel index (0-based)
   */
  animatePanelByIndex(index) {
    if (index < 0 || index >= this.panels.length) {
      console.warn(`Panel index ${index} out of range`);
      return;
    }
    
    const panel = this.panels[index];
    this.animatePanel(panel);
  }
  
  /**
   * Animate all panels at once (no stagger)
   */
  animateAllPanels() {
    this.panels.forEach((panel, index) => {
      // Add class immediately (no stagger)
      panel.classList.add('active');
      this.animated.add(index);
    });
    console.log('✅ All panels animated');
  }
  
  /**
   * Reset animation (remove active class)
   */
  reset() {
    this.panels.forEach((panel) => {
      panel.classList.remove('active');
    });
    this.animated.clear();
    console.log('🔄 Animation reset');
  }
  
  /**
   * Destroy the animation (clean up)
   */
  destroy() {
    if (this.observer) {
      this.observer.disconnect();
    }
    this.panels = [];
    this.animated.clear();
    console.log('🗑️ PanelAnimation destroyed');
  }
  
  /**
   * Re-initialize (for dynamic content)
   */
  refresh() {
    this.destroy();
    this.init();
  }
}

// ============================================
// AUTO-INITIALIZE
// ============================================

// Wait for DOM to be ready
document.addEventListener('DOMContentLoaded', function() {
  // Create animation instance
  const animation = new PanelAnimation({
    threshold: 0.3,      // 30% visible triggers animation
    staggerDelay: 100,   // 100ms between panels
    once: true,          // Animate only once
  });
  
  // Store globally for debugging
  window.panelAnimation = animation;
  
  // Optional: Log when panels animate
  document.addEventListener('panelAnimated', (e) => {
    console.log(`🎯 Panel ${e.detail.index + 1} animated with ${e.detail.delay}ms delay`);
  });
});

// ============================================
// ALTERNATIVE: SIMPLE STANDALONE FUNCTION
// ============================================

/**
 * A simpler function-based approach
 * Use this if you prefer a more minimal setup
 */
function initSimplePanelAnimation(selector = '.panel:not(:first-child)') {
  const panels = document.querySelectorAll(selector);
  const animated = new Set();
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const panel = entry.target;
        const index = Array.from(panels).indexOf(panel);
        
        if (animated.has(index)) return;
        
        const delay = index * 100; // 100ms stagger
        
        setTimeout(() => {
          panel.classList.add('active');
          animated.add(index);
          console.log(`✅ Panel ${index + 1} animated`);
        }, delay);
      }
    });
  }, {
    threshold: 0.3,
  });
  
  panels.forEach(panel => observer.observe(panel));
  
  console.log(`🎬 Watching ${panels.length} panels`);
  
  return observer;
}

