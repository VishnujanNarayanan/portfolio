document.querySelectorAll('.panel').forEach((p, i) => {
  console.log(`Panel ${i}: active = ${p.classList.contains('active')}`);
});

// Monitor panel changes
const observer = new MutationObserver((mutations) => {
  mutations.forEach(m => {
    if (m.target.classList.contains('active')) {
      console.log('Panel activated:', m.target);
    }
  });
});

document.querySelectorAll('.panel').forEach(p => {
  observer.observe(p, { attributes: true, attributeFilter: ['class'] });
});
```

### Common Issues & Solutions

| Issue | Solution |
|-------|----------|
| Panels not animating | Check IntersectionObserver support, ensure panels have `active` class |
| Animation too fast/slow | Adjust `transition-duration` in CSS |
| Stagger not working | Check delay values in CSS or JavaScript |
| Panel visible on load | Remove `active` class from panels, only keep first one |
| Fonts not loading | Check font paths, add fallback fonts |

